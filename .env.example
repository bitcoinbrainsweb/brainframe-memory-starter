# Memory Starter: environment variables.
# DO NOT put real values here. This file is committed to the repo.
# Real credentials go in ~/.config/memory-starter/.env (run scripts/onboard.sh),
# in your own .env that you do NOT commit, or in your secrets manager.

# ---------------------------------------------------------------------------
# File-based memory starter (original)
# ---------------------------------------------------------------------------
SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================================================
# harness/ : database-backed systems (see harness/README.md)
# ===========================================================================

# ---------------------------------------------------------------------------
# Shared: database + secrets manager (used by memory, sessions, foreman, council)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:pass@host:5432/dbname   # your Postgres connection string
SUPABASE_URL=https://YOUR_PROJECT.supabase.co        # your Supabase project URL (or leave blank for plain Postgres)
SUPABASE_SERVICE_KEY=your-service-role-key            # service role key; bypasses RLS. Keep secret.
SUPABASE_DB_URL=postgres://user:pass@host:5432/dbname # direct DB URL used by the foreman DB harness
# How the code fetches any secret not already in the environment. Point these at your
# own secrets manager; leave unset to use environment variables only.
SECRETS_MANAGER_GET=                                  # command that prints ONE secret by name, e.g. your-cli get --plain
SECRETS_DOWNLOAD_CMD=                                 # command that prints ALL secrets as one JSON object
SECRETS_JSON=                                         # or paste a JSON object of secrets directly (foreman DB harness)

# ---------------------------------------------------------------------------
# Foreman: build/verify loop
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key             # the build/verify agent loop (also used by the council)
# Set the build and verify model strings in harness/foreman/scripts/models.py.
# They MUST resolve to different model families.
GITHUB_PRIMARY_PAT=your-github-pat                   # PAT with repo + workflow scope for branch/push/merge
FOREMAN_SANDBOX_PUSH_TOKEN=                           # optional narrower-scoped push token, tried first
GH_TOKEN=                                             # optional fallback push token
FOREMAN_GPG_KEY_ID=                                   # optional: GPG key alias for signed commits
FOREMAN_AGENT_TOKEN_BUDGET=200000                    # per-run token budget for the agent loop
FOREMAN_AGENT_HTTP_TIMEOUT=120                       # seconds
FOREMAN_AGENT_MODEL_CAP=8096                          # max_tokens cap per model call
FOREMAN_GIT_TIMEOUT_SECONDS=120                      # hard ceiling on any single git subprocess
FOREMAN_TOKEN_VALIDATION_TIMEOUT_SECONDS=10          # push-token GitHub validation timeout
FOREMAN_CIRCUIT_BREAKER_N=3                          # repeat-failure circuit breaker threshold
FOREMAN_FIX_BUDGET=2                                  # fix passes allowed before parking a spec
TOOL_TRACE_ENABLED=false                             # optional build-agent tool-trace emission
TOOL_TRACE_INSERT_KEY=                               # restricted insert-only key for tool traces (never the service key)
TOOL_TRACE_RELAY_URL=                                # optional relay endpoint for tool traces
TOOL_TRACE_RELAY_KEY=                                # optional relay key

# ---------------------------------------------------------------------------
# Council: N independent critics (see harness/council/run_council.py CRITIC_SEATS)
# ---------------------------------------------------------------------------
# Seat 1 is an Anthropic model (uses ANTHROPIC_API_KEY above). Set its model string:
CRITIC_1_MODEL=your-anthropic-model
# Seats 2..5 are any OpenAI-compatible endpoints. Use DIFFERENT model families.
CRITIC_2_MODEL=your-critic-2-model
CRITIC_2_API_KEY=your-critic-2-key
CRITIC_2_BASE_URL=https://api.your-vendor-2.example/v1
CRITIC_3_MODEL=your-critic-3-model
CRITIC_3_API_KEY=your-critic-3-key
CRITIC_3_BASE_URL=https://api.your-vendor-3.example/v1
CRITIC_4_MODEL=your-critic-4-model
CRITIC_4_API_KEY=your-critic-4-key
CRITIC_4_BASE_URL=https://api.your-vendor-4.example/v1
CRITIC_5_MODEL=your-critic-5-model
CRITIC_5_API_KEY=your-critic-5-key
CRITIC_5_BASE_URL=https://api.your-vendor-5.example/v1
# The judge / merger / reviewer model (kept separate from the critics):
JUDGE_MODEL=your-judge-model
JUDGE_API_KEY=your-judge-key
JUDGE_BASE_URL=https://api.your-judge-vendor.example/v1
REGULATED_CLEARED_SEATS=                             # comma-separated seat ids cleared for regulated data

# ---------------------------------------------------------------------------
# Subagents: host-budgeted fan-out concurrency
# ---------------------------------------------------------------------------
HOST_MEMORY_BUDGET_MB=8192                            # memory you will let a fan-out use
SUBAGENT_EST_FOOTPRINT_MB=512                         # estimated peak memory per sub-worker
SUBAGENT_MAX_CONCURRENCY=16                           # hard ceiling regardless of the budget math
